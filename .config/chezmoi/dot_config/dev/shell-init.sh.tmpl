# ~/.config/dev/shell-init.sh — managed by chezmoi; edit the template in
# <dev>/.config/chezmoi/. Sourced from ~/.bashrc by a one-line hook that
# install.sh appends (your .bashrc stays yours — never overwritten).
export DEV_ROOT="{{ .devRoot }}"
export MISE_GLOBAL_CONFIG_FILE="$DEV_ROOT/.config/mise/core.toml"
export SOPS_AGE_KEY_FILE="$HOME/.config/sops/age/keys.txt"
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash)"
fi
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook bash)"
fi
