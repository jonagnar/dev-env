# ~/.config/dev/gitconfig — managed by chezmoi; pulled into your ~/.gitconfig
# via ONE [include] line that install.sh appends. Your own .gitconfig (identity
# overrides, safe.directory, editor, …) is never rewritten; anything you set
# there after the include line wins over these values.
[user]
    name = {{ .gitName }}
    email = {{ .gitEmail }}
[init]
    defaultBranch = main
    templateDir = ~/.config/git/template
[pull]
    ff = only
[core]
    excludesFile = ~/.config/git/ignore
# tea (Forgejo CLI) supplies HTTP credentials for the local Forgejo.
[credential "http://localhost:3000"]
    helper =
    helper = !tea login helper
[alias]
    st = status -sb
    co = checkout
    sw = switch
    br = branch
    ci = commit
    lg = log --oneline --graph --decorate -20
    last = log -1 HEAD --stat
    unstage = reset HEAD --
