# ~/.config/dev/gitconfig — managed by chezmoi; pulled into your ~/.gitconfig
# via ONE [include] line that install.sh appends. Your own .gitconfig (identity,
# credential helpers, safe.directory, editor, …) is never rewritten, and this
# file deliberately carries no [user] — your identity stays yours.
[init]
    defaultBranch = main
    templateDir = ~/.config/git/template
[pull]
    ff = only
[core]
    excludesFile = ~/.config/git/ignore
[alias]
    st = status -sb
    co = checkout
    sw = switch
    br = branch
    ci = commit
    lg = log --oneline --graph --decorate -20
    last = log -1 HEAD --stat
    unstage = reset HEAD --
