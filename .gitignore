# secrets — never commit plaintext or private keys
*.key
keys.txt
*.dec
.env
!.env.example
*.env
!*.env.sops
!*.env.example

# rendered sops config (machine-specific public recipient; init renders it from .sops.yaml.tmpl)
.config/sops/.sops.yaml

# gitignored holding folders (keep the folder, drop the contents)
src/*
!src/demo-api
!src/.gitkeep
# restore.sh staging dirs
restore-*/

# OS / editor noise
.DS_Store
Thumbs.db
